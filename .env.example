# ═══════════════════════════════════════════
# Smart Observatory — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in your keys:
#   cp .env.example .env.local

# APIFY_API_TOKEN: Required for LinkedIn, Google Trends, and App Reviews scrapers.
# Get your token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=""

# GOOGLE_MAPS_API_KEY: Required for Last-Mile Analytics (Places & Distance Matrix APIs).
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=""

# GROQ_API_KEY: Required for AI analysis (llama-3.3-70b via Groq).
# Get from https://console.groq.com/keys
GROQ_API_KEY=""

# TWITTER_API_IO_KEY: Required for Twitter/X gig economy sentiment analysis.
# Get from https://twitterapi.io
TWITTER_API_IO_KEY=""

# MAROOF_API_KEY: Fallback API key for Maroof store scraper.
# The scraper auto-captures the key from the Maroof website via Playwright,
# but this serves as a fallback if capture fails.
MAROOF_API_KEY=""

# VITE_TOMTOM_API_KEY: Optional — Real-Time Traffic Layer in Last-Mile Analytics.
# Get a free API key from https://developer.tomtom.com/
VITE_TOMTOM_API_KEY=""

# GEMINI_API_KEY: Optional — Only needed if deploying on Google AI Studio.
GEMINI_API_KEY=""
